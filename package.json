{
  "name": "samebase-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#lib/*": "./src/lib/*.ts",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "dev": "node ./scripts/run-dev.ts",
    "dev:frontend": "vp dev",
    "dev:worktree": "node ./scripts/run-worktree-dev.ts",
    "check": "tsc && tsc --project convex/tsconfig.json && pnpm run verify:cloudflare-redirects",
    "build": "vp run build:cloudflare",
    "build:app": "tsc && pnpm run generate:cloudflare-redirects && vp build",
    "build:cloudflare": "node ./scripts/build-cloudflare.ts",
    "deploy": "node ./scripts/deploy-cloudflare.ts deploy",
    "deploy:preview": "node ./scripts/deploy-cloudflare.ts preview",
    "deploy:dry-run": "node ./scripts/deploy-cloudflare.ts deploy --dry-run",
    "deploy:preview:dry-run": "node ./scripts/deploy-cloudflare.ts preview --dry-run",
    "generate:cloudflare-redirects": "node ./scripts/generate-cloudflare-redirects.ts",
    "verify:cloudflare-redirects": "pnpm run generate:cloudflare-redirects && git diff --exit-code -- public/_redirects",
    "preview": "vp preview",
    "prepare": "vp config"
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.92",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "^4.1.8",
    "wrangler": "^4.90.1"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
